{
  "name": "@ayudb1304/sushi",
  "version": "0.1.2",
  "description": "Build-in-Public Content Engine — transforms Git diffs into platform-specific social media drafts",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sushi": "dist/index.js"
  },
  "files": [
    "dist/index.*",
    "dist/commands/**",
    "dist/lib/**",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayudb1304-wq/bip-cli.git"
  },
  "homepage": "https://github.com/ayudb1304-wq/bip-cli#readme",
  "scripts": {
    "setup": "npm install && npm --prefix dashboard install",
    "build": "tsc",
    "build:all": "npm run build && npm run dashboard:build",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "dev": "tsx src/index.ts",
    "quickstart": "npm run dev -- quickstart",
    "demo": "npm run dev -- quickstart",
    "onboarding:smoke": "tsx scripts/onboarding-smoke.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "build-in-public",
    "cli",
    "git",
    "social-media",
    "developer-tools",
    "ai",
    "gemini",
    "twitter",
    "linkedin",
    "devlog"
  ],
  "author": "Ayush Bhiogade",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "inquirer": "^12.4.2",
    "js-yaml": "^4.1.0",
    "playwright": "^1.58.2",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
